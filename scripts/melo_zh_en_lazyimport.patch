+}
+_lang_module_cache = {}
+
+
+class _LazyLangModuleMap:
+    def __getitem__(self, language):
+        if language not in _lang_module_cache:
+            name = _LANG_MODULE_NAMES[language]
+            _lang_module_cache[language] = importlib.import_module(f".{name}", __package__)
+        return _lang_module_cache[language]
+
+
