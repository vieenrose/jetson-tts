+  def _band_mask(self, attn_mask):
+    # attn_mask: [B,1,T,T]. Keep key j for query i iff (j-i)<=lookahead and (i-j)<=past.
+    # Derive positions via cumsum(ones) along the real T axis so the trace stays
+    # DYNAMIC in T (torch.arange(shape[-1]) bakes a constant under onnx tracing).
+    ones = torch.ones_like(attn_mask[0, 0, 0, :])                 # [T]
