+# ============================================================================
+# Custom (phone, tone, lang) JSONL reader for the zh-TW/en MB-iSTFT-VITS build.
+# Each jsonl row: {phone_ids, tone_ids, lang_ids, hifigan_durations,
+#                  target_audio, text, speaker_id}. cleaned_text=True: ids are
+# fed directly (NO espeak / text-cleaner). Audio (48k) is resampled to the
+# config sampling_rate on load; linear spectrogram at filter/hop/win.
+# ============================================================================
+import json
+import soundfile as sf
+import librosa
+
+
+class JsonlTextAudioLoader(torch.utils.data.Dataset):
+    def __init__(self, jsonl_path, hparams):
+        self.sampling_rate = hparams.sampling_rate
+        self.filter_length = hparams.filter_length
+        self.hop_length    = hparams.hop_length
+        self.win_length    = hparams.win_length
+        self.min_phone_len = getattr(hparams, "min_phone_len", 4)
+        self.max_phone_len = getattr(hparams, "max_phone_len", 400)
+        self.max_wav_sec   = getattr(hparams, "max_wav_sec", 15.0)
+        self.add_blank     = getattr(hparams, "add_blank", False)
+
+        rows = []
+        with open(jsonl_path, encoding="utf-8") as f:
+            for line in f:
+                line = line.strip()
+                if line:
+                    rows.append(json.loads(line))
+        self.rows = self._filter(rows)
+        # spec lengths (for optional bucketing) ~ resampled_wav_len / hop
+        self.lengths = [r["_spec_len_est"] for r in self.rows]
+        random.seed(1234)
+        random.shuffle(self.rows)
+
+    def _filter(self, rows):
+        kept = []
+        for r in rows:
+            n = len(r["phone_ids"])
+            if not (self.min_phone_len <= n <= self.max_phone_len):
+                continue
+            if not (len(r["tone_ids"]) == n and len(r["lang_ids"]) == n):
+                continue
+            try:
+                info = sf.info(r["target_audio"])
+            except Exception:
+                continue
+            secs = info.frames / info.samplerate
+            if secs > self.max_wav_sec:
+                continue
+            r["_spec_len_est"] = int(secs * self.sampling_rate) // self.hop_length
+            kept.append(r)
+        return kept
+
+    def get_audio(self, filename):
+        audio, sr = sf.read(filename, dtype="float32", always_2d=False)
+        if audio.ndim > 1:
+            audio = audio.mean(axis=1)
+        if sr != self.sampling_rate:
+            audio = librosa.resample(audio, orig_sr=sr, target_sr=self.sampling_rate)
+        audio_norm = torch.FloatTensor(audio).clamp_(-1.0, 1.0).unsqueeze(0)  # [1, T], in [-1,1]
+        spec = spectrogram_torch(audio_norm, self.filter_length, self.sampling_rate,
+                                 self.hop_length, self.win_length, center=False)
+        spec = torch.squeeze(spec, 0)  # [freq, Tspec]
+        return spec, audio_norm
+
+    def __getitem__(self, index):
+        r = self.rows[index]
+        p, t, l = r["phone_ids"], r["tone_ids"], r["lang_ids"]
+        if self.add_blank:
+            # MeloTTS/VITS pattern: interleave blank id 0 on all 3 streams
+            p = commons.intersperse(p, 0)
+            t = commons.intersperse(t, 0)
+            l = commons.intersperse(l, 0)
+        phone = torch.LongTensor(p)
+        tone  = torch.LongTensor(t)
+        lang  = torch.LongTensor(l)
+        spec, wav = self.get_audio(r["target_audio"])
+        sid = int(r.get("speaker_id", 0))  # 0 for single-speaker corpora (v2/A24)
+        return (phone, tone, lang, spec, wav, sid)
+
+    def __len__(self):
+        return len(self.rows)
+
+
+class JsonlTextAudioCollate:
+    """Zero-pad (phone, tone, lang, spec, wav); sort by spec length descending."""
+    def __init__(self, return_ids=False):
+        self.return_ids = return_ids
+
+    def __call__(self, batch):
+        _, ids_sorted = torch.sort(
+            torch.LongTensor([x[3].size(1) for x in batch]), dim=0, descending=True)
+
+        max_text = max(x[0].size(0) for x in batch)
+        max_spec = max(x[3].size(1) for x in batch)
+        max_wav  = max(x[4].size(1) for x in batch)
+        n = len(batch)
+
+        text_lengths = torch.LongTensor(n)
+        spec_lengths = torch.LongTensor(n)
+        wav_lengths  = torch.LongTensor(n)
+
+        phone_padded = torch.zeros(n, max_text, dtype=torch.long)
+        tone_padded  = torch.zeros(n, max_text, dtype=torch.long)
+        lang_padded  = torch.zeros(n, max_text, dtype=torch.long)
+        spec_padded  = torch.zeros(n, batch[0][3].size(0), max_spec)
+        wav_padded   = torch.zeros(n, 1, max_wav)
+        sid          = torch.zeros(n, dtype=torch.long)
+
+        for i in range(len(ids_sorted)):
+            phone, tone, lang, spec, wav, s = batch[ids_sorted[i]]
+            phone_padded[i, :phone.size(0)] = phone
+            tone_padded[i,  :tone.size(0)]  = tone
+            lang_padded[i,  :lang.size(0)]  = lang
+            text_lengths[i] = phone.size(0)
+            spec_padded[i, :, :spec.size(1)] = spec
+            spec_lengths[i] = spec.size(1)
+            wav_padded[i, :, :wav.size(1)] = wav
+            wav_lengths[i] = wav.size(1)
+            sid[i] = s
+
+        out = (phone_padded, tone_padded, lang_padded, text_lengths,
+               spec_padded, spec_lengths, wav_padded, wav_lengths, sid)
+        if self.return_ids:
+            return out + (ids_sorted,)
+        return out
